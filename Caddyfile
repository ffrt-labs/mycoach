# Fronts MyCoach with HTTPS so the /logger PWA can be installed and its
# service worker can register (both require a secure context). This only
# ever needs to be valid on the LAN — install and sync both happen at home
# — so DNS-01 gets a real, browser-trusted cert with zero inbound ports and
# no internet exposure.
#
# {$VAR} substitutes at Caddy startup from the container's environment
# (populated by docker-compose's `env_file: .env`), so nothing personal
# lives in this file. See .env.example for MYCOACH_DOMAIN and
# CLOUDFLARE_API_TOKEN.

{$MYCOACH_DOMAIN} {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
	reverse_proxy app:8000
}
