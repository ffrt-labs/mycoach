# MyCoach Configuration
# Copy this file to .env and fill in your values

# App
MYCOACH_ENV=development
MYCOACH_DEBUG=false
MYCOACH_LOG_LEVEL=INFO
MYCOACH_API_TOKEN=
MYCOACH_TIMEZONE=Europe/London

# Security — generate with: python -c "from mycoach.crypto import generate_key; print(generate_key())"
MYCOACH_ENCRYPTION_KEY=

# Database
MYCOACH_DB_URL=sqlite+aiosqlite:///./mycoach.db

# Garmin (Phase 1)
MYCOACH_GARMIN_EMAIL=
MYCOACH_GARMIN_PASSWORD=
MYCOACH_GARMIN_TOKEN_DIR=.garmin_tokens

# Hevy API
MYCOACH_HEVY_EMAIL=
MYCOACH_HEVY_PASSWORD=
# One-time bootstrap: log into hevy.com in a browser, capture the POST to
# api.hevyapp.com/login (or /auth/refresh_token) in DevTools, and paste its
# refresh_token here. The app rotates and persists it in MYCOACH_HEVY_TOKEN_DIR
# after that, so this only needs to be set once (until the token is revoked).
MYCOACH_HEVY_REFRESH_TOKEN=
# Must point at a PERSISTENT location (a mounted Docker volume in production) so
# the rotated refresh token survives redeploys — otherwise every deploy reverts
# to the stale seed above and Hevy sync fails. See docker-compose.yml.
MYCOACH_HEVY_TOKEN_DIR=.hevy_tokens

# LLM Provider — "anthropic" or "gemini" (add more in coaching/providers/)
MYCOACH_LLM_PROVIDER=anthropic

# Anthropic Claude API
MYCOACH_CLAUDE_API_KEY=
MYCOACH_CLAUDE_MODEL_DAILY=claude-sonnet-4-5-20250929
MYCOACH_CLAUDE_MODEL_WEEKLY=claude-opus-4-6
MYCOACH_CLAUDE_MONTHLY_COST_CEILING=30.0

# Google Gemini API
MYCOACH_GEMINI_API_KEY=
MYCOACH_GEMINI_MODEL_DAILY=gemini-2.5-flash
MYCOACH_GEMINI_MODEL_WEEKLY=gemini-2.5-pro

# Email (Phase 7)
MYCOACH_EMAIL_ENABLED=false
MYCOACH_EMAIL_FROM=
MYCOACH_EMAIL_TO=
MYCOACH_EMAIL_SMTP_HOST=
MYCOACH_EMAIL_SMTP_PORT=587
MYCOACH_EMAIL_SMTP_USER=
MYCOACH_EMAIL_SMTP_PASSWORD=
MYCOACH_EMAIL_RESEND_API_KEY=

# Scheduler (Phase 5)
MYCOACH_SCHEDULER_TIMEZONE=Europe/London
MYCOACH_SCHEDULER_SYNC_HOUR=6
MYCOACH_SCHEDULER_SYNC_MINUTE=0
MYCOACH_SCHEDULER_BRIEFING_HOUR=6
MYCOACH_SCHEDULER_BRIEFING_MINUTE=30
MYCOACH_SCHEDULER_WEEKLY_PLAN_DAY=sun
MYCOACH_SCHEDULER_WEEKLY_PLAN_HOUR=18
